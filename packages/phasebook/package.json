{
  "name": "phasebook",
  "version": "1.0.0",
  "description": "Interactive 3D book component for React",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "require": "./dist/server.js",
      "import": "./dist/server.mjs",
      "types": "./dist/server.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./dist/styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.tsx --clean --format cjs,esm --dts --no-splitting --external react,react-dom,framer-motion,lucide-react && tsup src/server.tsx --format cjs,esm --dts --no-splitting --external react,react-dom,framer-motion,lucide-react,./index && tailwindcss -i src/styles.css -o dist/styles.css",
    "dev": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "framer-motion": "^10.0.0 || ^11.0.0 || ^12.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.1",
    "lucide-react": "^1.22.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
